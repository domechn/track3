<!DOCTYPE html>
<html>
  <head>
    <title>Assets Statistics</title>
  </head>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <body>
    <canvas
      id="asset-change"
      style="max-height: {{=it.maxHeight}}px"
    ></canvas>

    <script>
      const ctx = document.getElementById("asset-change");

      const data = {
        labels: {{=it.labels}},
        datasets: [
          {
	    label: "USD Value",
            data: {{=it.data}},
            borderColor: "{{=it.color}}",
            backgroundColor: "{{=it.color}}",
            borderWidth: 5,
            tension: 0.1,
            pointRadius: 1,
            pointStyle: 'rotRect'
          },
        ],
      };

      const options = {
        plugins: {
          title: {
            display: true,
            text: "Trend of Asset USD Value",
          },
        },
        scales: {
          x: {
            title: {
              display: true,
              text: "Date",
            },
          },
          y: {
            title: {
              display: true,
              text: "USD",
            },
            offset: true,
            ticks: {
              precision: 2,
            },
            grid: {
              display: false,
            }
          },
        },
      };

      const config = {
        type: "line",
        data,
        options,
      };

      new Chart(ctx, config);
    </script>
  </body>
</html>
