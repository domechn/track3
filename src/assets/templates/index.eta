<!DOCTYPE html>
<html>
  <head>
    <title>Assets Statistics</title>
  </head>
  <body>
  <div style="padding: 20px 10px;">
  {{ it.templates.forEach((templateList, listIdx) => { }}
    <div>
    {{ templateList.forEach((template, idx) => { }}
        <div
          class="expand-icon"
          style="top: {{=(it.height * listIdx + 20)}}px; right: {{= 100 - ( 95 / templateList.length ) * ( idx + 1 )  }}%;"
        >
          <svg
            id="expand-or-collapse-icon"
            viewBox="0 0 1024 1024"
            onclick="expandOrCollapse('{{= template }}.html')"
            fill="#c0c0c0"
          >
            <path
              d="M1024 0v416l-160-160-192 192-96-96 192-192-160-160zM448 672l-192 192 160 160h-416v-416l160 160 192-192z"
            />
          </svg>
        </div>
    <iframe
      src="{{= template }}.html"
      class="iframeBox"
      scrolling="no"
      frameborder="0"
      style="width: {{= 95 / templateList.length }}%;"
      name="template"
    ></iframe>
    {{ }) }}
    </div>
  {{ }) }}
  </div>
  </body>

  <style>
    .iframeBox {
      border: none;
      height: {{=it.height}}px;
    }
    .expand-icon {
      position: absolute;
      width: 20px;
      height: 20px;
      cursor: pointer;
    }
  </style>


  <script>
    function expandOrCollapse(jumpTo) {
      let that = window;
      if (window != top) {
        that = top;
      }
      top.location.href = jumpTo;
    }
  </script>
</html>
